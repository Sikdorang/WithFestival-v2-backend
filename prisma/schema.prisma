// Store = 기존 booth. 주문 그룹(Order) · 상세(OrderItem) · 대기(Waiting) · 메뉴(Menu)

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Store {
  id            Int    @id @default(autoincrement())
  name          String @db.VarChar(200)
  accountNumber String? @db.VarChar(100)
  notice        String? @db.Text
  event         String? @db.VarChar(500)
  reservationEnabled Boolean @default(false)
  missionsEnabled    Boolean @default(false)
  /// 기존 number 역할
  authCode      String @db.VarChar(64)

  createdAt DateTime @default(now())

  menus    Menu[]
  waitings Waiting[]
  orders   Order[]
  reservationSlots ReservationSlot[]
  missions Mission[]

  @@unique([authCode])
}

model Mission {
  id          Int      @id @default(autoincrement())
  storeId     Int
  missionName String   @db.VarChar(200)
  description String?  @db.Text
  reward      String   @db.VarChar(500)
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([storeId, isActive])
}

model Menu {
  id          Int     @id @default(autoincrement())
  storeId     Int
  name        String  @db.VarChar(200)
  price       Int
  description String? @db.Text
  imageUrl    String? @db.VarChar(512)
  /// soft delete
  deleted     Boolean  @default(false)

  store      Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([storeId])
  @@index([storeId, deleted])
}

model Order {
  id         Int @id @default(autoincrement())
  storeId    Int
  /// 테이블(좌석) 식별자 — URL `tableId`와 동일하게 저장
  tableId    Int

  totalPrice Int
  /// RECEIVED: 접수됨 · COMPLETED: 처리 완료 · CANCELED: 취소
  status OrderStatus @default(RECEIVED)

  /// 결제 상태 (기존 `paymentCheck Boolean` 대신 enum으로 통일)
  paymentStatus PaymentStatus @default(PENDING)

  customerName String? @db.VarChar(200)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items OrderItem[]

  @@index([storeId])
  @@index([storeId, tableId])
}

model OrderItem {
  id       Int @id @default(autoincrement())
  orderId  Int
  menuId   Int
  quantity Int
  /// 주문 시점 스냅샷 가격
  price    Int

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menu  Menu  @relation(fields: [menuId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([menuId])
}

model Waiting {
  id          Int @id @default(autoincrement())
  storeId     Int
  name        String @db.VarChar(200)
  partySize   Int
  phoneNumber String? @db.VarChar(32)
  /// WAITING: 줄서기 대기 중 · ENTERED: 입장 처리됨 · CANCELED: 취소
  status      WaitingStatus @default(WAITING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

model ReservationSlot {
  id              Int      @id @default(autoincrement())
  storeId         Int
  startTime       String   @db.VarChar(32)
  endTime         String   @db.VarChar(32)
  availableTables Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store        Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  reservations Reservation[]

  @@index([storeId])
}

model Reservation {
  id                Int      @id @default(autoincrement())
  reservationSlotId Int
  reserverName      String   @db.VarChar(200)
  phoneNumber       String   @db.VarChar(32)
  partySize         Int
  deleted           Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  reservationSlot ReservationSlot @relation(fields: [reservationSlotId], references: [id], onDelete: Cascade)

  @@index([reservationSlotId])
  @@index([reservationSlotId, deleted])
}

enum OrderStatus {
  RECEIVED
  COMPLETED
  CANCELED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum WaitingStatus {
  WAITING
  ENTERED
  CANCELED
}
